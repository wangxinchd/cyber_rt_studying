# 用于测试共享内存通讯
# 
# 两个节点 planning 和 loc 通过 mainboard 在同一个机器上面拉起来
# 如果是两个 dag 文件分别拉起，是两个进程，采用共享内存通讯
# 如果通过一个 dag 文件一次性拉起 planning 和 loc，此时是一个进程中

module_config {
    module_library : "/mnt/sd_data/git_project/sim_plan/sim_plan/cyber_rt_studying/install/lib/libtest_reader.so"
    components {
        class_name : "ReaderComponent"
        config {
            name : "loc"
            readers {
                channel : "channel/class01_test"
            }
        }
    }
}
